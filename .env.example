# crawler-qa-agent — copy to .env and fill in. See README for details.

# Claude auth — run `claude setup-token` to get the OAuth token
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-xxxxx
PORT=3200
# Dashboard first-admin seed (needed to log in on a fresh install)
QA_ADMIN_USER=admin
QA_ADMIN_PASSWORD=change-me
QA_KEEP_BROWSER_OPEN=1
SETUP_MAX_ITERATIONS=20
GAME_URL=https://pp.dev.revenge-games.com/<slug>/?t=...&oc=demo&l=en
DATABASE_URL=postgresql://postgres@localhost:5432/crawler_qa
# Loosen safe-click whitelist so explorer reaches 3-level popups (dev/demo only).
QA_AGGRESSIVE_DISCOVER=1
QA_HEADLESS=0
QA_RECORD_VIDEO=1
RG_E2E_API_KEY=

# Optional — route the game browser through a proxy/VPN for geo-restricted games
# (only the browser is tunneled; server traffic stays direct). Unset = no proxy.
# QA_PROXY=socks5://127.0.0.1:1080        # e.g. ssh -D 1080 user@vps-in-region
# QA_PROXY_USER=
# QA_PROXY_PASS=
# QA_PROXY_BYPASS=*.local,127.0.0.1
