# ============================================================================
# crawler-qa-agent — environment configuration
# ============================================================================

# ─── REQUIRED ─────────────────────────────────────────────────────────────
# Claude auth. Dashboard và CLI đều dùng. Copy từ Claude Code OAuth token,
# hoặc dùng ANTHROPIC_API_KEY nếu muốn key thường.
CLAUDE_CODE_OAUTH_TOKEN=
# ANTHROPIC_API_KEY=


# ─── DASHBOARD MODE (khuyên dùng) ─────────────────────────────────────────
# Khởi chạy:  npm run serve
# Mở:          http://localhost:3100/dashboard
# → Paste Game URL vào form "New Task" của UI — KHÔNG cần GAME_URL ở đây.
# Server sẽ tự inject GAME_URL per-task khi spawn subprocess.

# Port dashboard (default 3100)
# PORT=3100


# ─── CLI MODE (optional, chỉ khi không dùng dashboard) ────────────────────
# GAME_URL chỉ cần set khi chạy trực tiếp:
#   npm run qa
#   npm run auto
#   npm run rules
#   npm run options
# Hoặc có thể truyền qua CLI arg:
#   npm run qa -- 'https://game-url.../?t=...'
# Khi chạy qua dashboard, env này BỎ QUA.

# GAME_URL=https://rc.dev.revenge-games.com/fortune-pig/?t=...


# ─── OPTIONAL TUNING ──────────────────────────────────────────────────────

# Giữ browser mở sau khi test xong (để inspect tay). Áp dụng cho: auto, rules,
# options, qa. Script sẽ chờ user đóng cửa sổ browser tay rồi mới kết thúc.
# QA_KEEP_BROWSER_OPEN=1

# Force URL language → rewrite tham số ?l= / ?lang= của game URL.
# Dùng "en" để giảm AI transcribe nhầm trên UI ngôn ngữ hiếm.
# QA_FORCE_LANG=en

# Bỏ qua cache bootstrap (rules + auto) và re-collect mọi thứ.
# QA_FORCE=1

# Dừng sau Phase B (chỉ sinh GameSpec + test code, không chạy Playwright).
# Dùng để review/edit generated test trước khi chạy.
# QA_SKIP_EXEC=1

# Số spin trong generated Playwright test (default 3).
# QA_SPINS_PER_TEST=10

# Bootstrap: số spin cho auto-play khi chưa có sample (default 1).
# QA_BOOTSTRAP_SPINS=1

# Bootstrap: max pages cho extract-rules (default 6).
# QA_BOOTSTRAP_RULES_PAGES=6

# extract-rules: max iterations AI navigate (default 40).
# RULES_MAX_ITERATIONS=40

# extract-rules: max pages capture (default 10).
# RULES_MAX_PAGES=10

# extract-options: max iterations AI navigate (default 25).
# OPTIONS_MAX_ITERATIONS=25

# auto-play: số spin target (default 3).
# AUTO_SPIN_COUNT=3

# auto-play: timeout chờ authorize-game (default 90_000 ms).
# AUTO_LOAD_TIMEOUT_MS=90000

# Số iteration tối đa để AI dismiss mọi blocker cho tới khi play screen ready
# (age gate, terms, cookies, welcome, tutorial, loading). Default 25.
# Với game nhiều popup: tăng lên 30-40.
# PRE_GAME_MAX_ITERATIONS=25

# Scope prefix cho filename screenshots. Được qa pipeline tự set per-phase
# (rules/auto/test). Khi chạy standalone có thể override thủ công.
# QA_SCREENSHOT_SCOPE=manual

# Override output folder cho screenshots (thường được tự set per task-ID).
# QA_SCREENSHOT_DIR=/custom/path

# Loosen safe-click whitelist for graph explorer so depth-2/3 popups (buy-bonus
# tier options → confirm Yes/No, autoplay sub-options, etc.) get explored.
# Only CRITICAL commits (spin/start/yes/confirm/gamble/double) stay blocked.
# Use for dev/demo where balance is fake. Default unset = production-safe mode.
# QA_AGGRESSIVE_DISCOVER=1
