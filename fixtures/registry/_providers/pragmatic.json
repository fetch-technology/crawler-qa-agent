{
  "name": "Pragmatic",
  "wireFormat": "querystring",
  "urlPatterns": [
    "/gs2c/ge/",
    "/gs2c/.*gameservice",
    "/gs2c/.*playgame",
    "/gs2c/.*dogame",
    "/gs2c/.*dospin",
    "/gs2c/",
    "pragmatic",
    "sandbox\\.pragmatic",
    "prerelease-d2",
    "\\/\\/pp\\.",
    "\\bpp\\.\\w",
    "vs\\d+\\w+",
    "vsways\\w+",
    "vscluster\\w+",
    "vshades\\w+",
    "vshorus\\w+",
    "vsfun\\w+"
  ],
  "skipUrlPatterns": [
    "/gs2c/(?:stats|saveSettings|html5Game|openGame)\\.do",
    "/gs2c/common/"
  ],
  "nonSpinActions": [
    "doInit",
    "doSettings",
    "doBonus",
    "doAuth",
    "doHistory",
    "doLogout",
    "doHeartbeat"
  ],
  "spinRequiredParams": ["c"],
  "response": {
    "fields": {
      "balanceBefore": "bb|balanceBefore",
      "balanceAfter": "balance_cash|balance|ba",
      "totalWin": "tw|totalWin",
      "initialReels": "s",
      "cascadeFrames": "sa",
      "freeSpinsRemaining": "fs",
      "roundIndex": "index",
      "roundAction": "na",
      "reelWidth": "sw",
      "reelHeight": "sh"
    },
    "reelsDecoder": "column_major",
    "defaultReelDimensions": { "width": 5, "height": 3 },
    "shapeScore": {
      "requiredFields": ["na", "tw"],
      "bonusFields": ["c", "sw", "sh", "sa", "sb", "s", "bl", "fs", "index", "bb", "ba", "balance", "balance_cash"],
      "minScore": 4
    },
    "nestedExtractions": [
      {
        "sourceField": "g",
        "pattern": "gp:\\{[^}]*?\\bs:\"([^\"]+)\"",
        "targetField": "s"
      },
      {
        "sourceField": "g",
        "pattern": "gp:\\{[^}]*?\\bsa:\"([^\"]+)\"",
        "targetField": "sa"
      }
    ]
  },
  "request": {
    "fields": {
      "coin": "c",
      "betLevel": "bl",
      "lines": "l",
      "roundIdParts": ["index", "counter"]
    },
    "betFormula": "coin * betLevel | coin * lines"
  },
  "roundId": {
    "source": "request",
    "fields": ["index", "counter"],
    "format": "req-{0}-{1}",
    "fallback": "response_hash"
  },
  "roundEndSignals": [
    {
      "urlPattern": "/gs2c/.*gameservice",
      "bodyPattern": "action=doCollect"
    }
  ]
}
