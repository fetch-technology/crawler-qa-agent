{
  "name": "crawler-qa-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Playwright-based QA automation for Revenge Games canvas games",
  "type": "module",
  "scripts": {
    "postinstall": "playwright install chromium",
    "serve:daemon": "pm2 start ecosystem.config.cjs",
    "serve:stop": "pm2 stop qa",
    "serve:restart": "pm2 restart qa --update-env",
    "serve:logs": "pm2 logs qa",
    "serve:status": "pm2 status qa",
    "qa": "tsx src/pipeline/cli/qa.ts",
    "qa:cold": "tsx src/pipeline/cli/qa-cold.ts",
    "qa:warm": "tsx src/pipeline/cli/qa-warm.ts",
    "open-game": "tsx src/pipeline/cli/open-game.ts",
    "discover-ui": "tsx src/pipeline/cli/discover-ui.ts",
    "save-ui-registry": "tsx src/pipeline/cli/save-ui-registry.ts",
    "capture-network": "tsx src/pipeline/cli/capture-network.ts",
    "detect-provider": "tsx src/pipeline/cli/detect-provider.ts",
    "detect-apis": "tsx src/pipeline/cli/detect-apis.ts",
    "discover-features": "tsx src/pipeline/cli/discover-features.ts",
    "audit:ai-scope": "tsx src/pipeline/cli/audit-ai-scope.ts",
    "save-provider-cache": "tsx src/pipeline/cli/save-provider-cache.ts",
    "load-ui-registry": "tsx src/pipeline/cli/load-ui-registry.ts",
    "load-provider-cache": "tsx src/pipeline/cli/load-provider-cache.ts",
    "validate-ui-registry": "tsx src/pipeline/cli/validate-ui-registry.ts",
    "ai-recover-locator": "tsx src/pipeline/cli/ai-recover-locator.ts",
    "generate-testcases": "tsx src/pipeline/cli/generate-testcases.ts",
    "apply-template-set": "tsx src/pipeline/cli/apply-template-set.ts",
    "run-scenario": "tsx src/pipeline/cli/run-scenario.ts",
    "verify-ui": "tsx src/pipeline/cli/verify-ui.ts",
    "verify-api": "tsx src/pipeline/cli/verify-api.ts",
    "verify-balance": "tsx src/pipeline/cli/verify-balance.ts",
    "run-spins": "tsx src/pipeline/cli/run-spins.ts",
    "calculate-rtp": "tsx src/pipeline/cli/calculate-rtp.ts",
    "generate-report": "tsx src/pipeline/cli/generate-report.ts",
    "serve": "tsx src/server/index.ts",
    "clean": "tsx src/clean.ts",
    "stats": "tsx src/statistical/cli.ts",
    "db:up": "docker compose up -d postgres redis",
    "db:down": "docker compose down",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset --force",
    "db:studio": "prisma studio",
    "worker:stats": "tsx src/queue/stats-worker.ts",
    "analyze:game": "tsx src/ai/game-analyzer-cli.ts",
    "bug-summary": "tsx src/ai/bug-summarizer-cli.ts",
    "stats:currency-batch": "tsx src/statistical/currency-batch-cli.ts",
    "lane:pr": "tsx src/lanes/run-lane.ts pr",
    "lane:pr:dry": "tsx src/lanes/run-lane.ts pr --dry-run",
    "lane:nightly": "tsx src/lanes/run-lane.ts nightly",
    "lane:nightly:dry": "tsx src/lanes/run-lane.ts nightly --dry-run",
    "review:diff": "tsx src/review/generate-diff-checklist.ts",
    "review:diff:stdout": "tsx src/review/generate-diff-checklist.ts --out=docs/qa-diff-review-checklist.md && cat docs/qa-diff-review-checklist.md",
    "review:signoff:init": "tsx src/review/generate-human-signoff.ts",
    "review:signoff:stdout": "tsx src/review/generate-human-signoff.ts --out=docs/qa-human-signoff.md && cat docs/qa-human-signoff.md",
    "test": "playwright test",
    "test:invariants": "playwright test tests/invariants/",
    "validate:registry": "tsx src/pipeline/cli/validate-registry.ts",
    "compile:knowledge": "tsx src/pipeline/cli/compile-knowledge.ts",
    "test:deterministic": "playwright test tests/deterministic-example.spec.ts",
    "test:hybrid": "playwright test tests/deterministic-hybrid.spec.ts",
    "test:integration": "playwright test tests/deterministic-integration.spec.ts",
    "report": "playwright show-report"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.118",
    "@anthropic-ai/sdk": "^0.88.0",
    "@playwright/mcp": "^0.0.70",
    "@prisma/client": "^6.19.3",
    "bullmq": "^5.76.8",
    "ioredis": "^5.10.1",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.7.0",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "dotenv": "^16.4.5",
    "pixelmatch": "^7.2.0",
    "playwright": "^1.60.0",
    "pngjs": "^7.0.0",
    "prisma": "^6.19.3",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
