{
  "name": "crawler-qa-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Playwright-based QA automation for Revenge Games canvas games",
  "type": "module",
  "scripts": {
    "record": "tsx src/discovery/record-traffic.ts",
    "analyze": "tsx src/discovery/analyze.ts",
    "auto": "tsx src/auto-play.ts",
    "record-pregame": "QA_CAPTURE_PREGAME=1 tsx src/auto-play.ts",
    "record-ui-flows": "tsx src/runner/record-ui-flows.ts",
    "capture-fs-buy": "tsx src/runner/capture-fs-via-buy.ts",
    "pregame-stats": "tsx src/runner/pre-game-stats-cli.ts",
    "rules": "tsx src/extract-rules.ts",
    "options": "tsx src/extract-options.ts",
    "qa": "tsx src/generate-and-run.ts",
    "serve": "tsx src/server/index.ts",
    "clean": "tsx src/clean.ts",
    "extract-scenarios": "tsx src/runner/scenario-extractor.ts",
    "stats": "tsx src/statistical/cli.ts",
    "db:up": "docker compose up -d postgres redis",
    "db:down": "docker compose down",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset --force",
    "db:studio": "prisma studio",
    "worker:stats": "tsx src/queue/stats-worker.ts",
    "analyze:game": "tsx src/ai/game-analyzer-cli.ts",
    "bug-summary": "tsx src/ai/bug-summarizer-cli.ts",
    "stats:currency-batch": "tsx src/statistical/currency-batch-cli.ts",
    "balance-trace": "tsx src/runner/balance-trace-cli.ts",
    "measure-catalog": "tsx src/measure-catalog.ts",
    "measure-preflight": "tsx src/measure-preflight.ts",
    "measure:automation": "tsx src/measure-automation.ts",
    "measure:scenario-min": "tsx src/measure-scenario-min.ts",
    "measure:skip-projection": "tsx src/measure-skip-projection.ts",
    "lane:pr": "tsx src/lanes/run-lane.ts pr",
    "lane:pr:dry": "tsx src/lanes/run-lane.ts pr --dry-run",
    "lane:nightly": "tsx src/lanes/run-lane.ts nightly",
    "lane:nightly:dry": "tsx src/lanes/run-lane.ts nightly --dry-run",
    "review:diff": "tsx src/review/generate-diff-checklist.ts",
    "review:diff:stdout": "tsx src/review/generate-diff-checklist.ts --out=docs/qa-diff-review-checklist.md && cat docs/qa-diff-review-checklist.md",
    "review:signoff:init": "tsx src/review/generate-human-signoff.ts",
    "review:signoff:stdout": "tsx src/review/generate-human-signoff.ts --out=docs/qa-human-signoff.md && cat docs/qa-human-signoff.md",
    "test": "playwright test",
    "test:deterministic": "playwright test tests/deterministic-example.spec.ts",
    "test:hybrid": "playwright test tests/deterministic-hybrid.spec.ts",
    "test:integration": "playwright test tests/deterministic-integration.spec.ts",
    "report": "playwright show-report"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.118",
    "@anthropic-ai/sdk": "^0.88.0",
    "@prisma/client": "^6.19.3",
    "bullmq": "^5.76.8",
    "ioredis": "^5.10.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.7.0",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "dotenv": "^16.4.5",
    "pixelmatch": "^7.2.0",
    "playwright": "^1.60.0",
    "pngjs": "^7.0.0",
    "prisma": "^6.19.3",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
