{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "noUncheckedIndexedAccess": true,
    "outDir": "dist",
    "rootDir": "src"
  },
  "include": ["src/**/*.ts", "tests/**/*.ts"],
  "exclude": ["node_modules", "dist", "fixtures", "reports", "tests/generated", "tests/deterministic-example.spec.ts", "tests/deterministic-integration.spec.ts", "tests/deterministic-hybrid.spec.ts", "tests/adapter-resolve.spec.ts", "tests/mechanics.spec.ts", "tests/pre-game-replay.spec.ts"]
}
