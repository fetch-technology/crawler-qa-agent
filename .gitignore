# ===== Dependencies & build =====
node_modules/
dist/
*.tsbuildinfo
coverage/
.playwright-mcp/

# ===== Reports & test outputs =====
reports/
playwright-report/
test-results/
tests/generated/

# ===== Env & secrets =====
.env
.env.local
.env.*.local

# ===== OS / editor =====
.DS_Store
**/.DS_Store
.vscode/
.idea/

# ===== Logs =====
*.log
npm-debug.log*
yarn-error.log*
# pm2 daemon logs (ecosystem.config.cjs writes qa.out.log / qa.err.log here)
logs/

# ===== Local tooling =====
.claude/settings.local.json
.claude/local/

# ===== Legacy / unused fixture dirs =====
fixtures/recordings/
fixtures/rules/
fixtures/options/
fixtures/specs/
fixtures/tasks/

# ===== Auth — QA accounts & login sessions (SECRETS, never commit) =====
fixtures/auth/

# ===== Runtime / derived fixtures (regeneratable) =====
# Per-run outputs — HTML/PDF/JSON reports, screenshots
fixtures/test-runs/

# Statistical run dumps — per-spin request/response
fixtures/statistical/

# Legacy case-actions & scenarios (being cleaned up)
fixtures/case-actions/
fixtures/scenarios/

# AI review outputs (regenerable from runs)
fixtures/reviews/

# Vision / AI debug dumps
fixtures/debug/

# ===== Per-game registry (LOCAL-ONLY — not versioned) =====
# The entire learned registry is per-MACHINE state, re-derived by onboarding
# each game (ui-registry, provider-cache, parser overlays, test-cases, paytable,
# plus all runtime artifacts: case-evidence, discovery-snapshots, network/,
# debug-*, _onboard-state, rtp-runs). It is NOT shared via git — each host
# onboards its own games.
fixtures/registry/

# Pregame stats (append-only log, regenerates)
fixtures/pre-game/_stats.jsonl

# Token-usage logs (append-only per-day, regenerates)
fixtures/usage/

# ===== Stray debug PNGs from Playwright MCP =====
# Older agent runs wrote browser_take_screenshot output to CWD = repo root
# (file names like `pre-click-betMinus-bet-1.13.png`, `after-autoplay.png`).
# Code now passes --output-dir → fixtures/registry/<slug>/debug-agent/, but
# guard the root anyway in case a callsite is missed or run from CWD again.
/*.png
